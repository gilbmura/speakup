# SpeakUp Environment Configuration
# Copy this file to .env and update values

# Application
APP_SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (Docker)
DATABASE_URL=mysql+pymysql://speakup:speakup123@db:3306/speakup

# Database (Local Windows - update with your MySQL credentials)
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/speakup

# File uploads
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=5

# SLA settings
SLA_DAYS=30
